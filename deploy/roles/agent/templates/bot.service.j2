# bot.service — 由 Ansible 自动生成
# v3 - 使用 sentinel 专用账户运行

[Unit]
Description=StockSentinel Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ sentinel_user }}
Group={{ sentinel_user }}
WorkingDirectory={{ sentinel_path }}
EnvironmentFile={{ sentinel_path }}/.env
ExecStart={{ sentinel_path }}/venv/bin/python -m agent.bot
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier={{ service_name }}

[Install]
WantedBy=multi-user.target
