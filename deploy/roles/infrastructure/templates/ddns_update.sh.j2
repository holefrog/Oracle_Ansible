#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="/var/lib/ddns/last_ip"
TMP_FILE="/tmp/ddns_ip.$$"
LOG_FILE="/var/log/changeip_ddns.log"

CIPUSER="{{ changeip_username }}"
CIPPASS="{{ changeip_password }}"
CIPHOST="{{ domain }}"

get_public_ip() {
  local ip=""

  ip="$(curl -fsS --max-time 8 https://checkip.amazonaws.com 2>/dev/null | tr -d '\r\n' || true)"
  if [[ "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    printf '%s\n' "$ip"
    return 0
  fi

  ip="$(curl -fsS --max-time 8 https://api.ipify.org 2>/dev/null | tr -d '\r\n' || true)"
  if [[ "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    printf '%s\n' "$ip"
    return 0
  fi

  ip="$(curl -fsS --max-time 8 https://ifconfig.me/ip 2>/dev/null | tr -d '\r\n' || true)"
  if [[ "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    printf '%s\n' "$ip"
    return 0
  fi

  return 1
}

log_line() {
  printf '%s %s\n' "$(date '+%F %T')" "$1" >> "$LOG_FILE"
}

mkdir -p /var/lib/ddns

if ! current_ip="$(get_public_ip)"; then
  log_line "[ERROR] Unable to resolve public IPv4"
  exit 1
fi

last_ip=""
if [[ -f "$STATE_FILE" ]]; then
  last_ip="$(cat "$STATE_FILE" 2>/dev/null || true)"
fi

if [[ "$current_ip" == "$last_ip" ]]; then
  log_line "[INFO] Public IP unchanged: $current_ip"
  exit 0
fi

update_url="https://nic.changeip.com/nic/update?system=dyndns&u=${CIPUSER}&p=${CIPPASS}&hostname=${CIPHOST}"
response="$(curl -fsS --max-time 15 "$update_url" 2>/dev/null || true)"

if [[ "$response" == *"good"* || "$response" == *"nochg"* || "$response" == *"Good"* || "$response" == *"Nochg"* ]]; then
  printf '%s\n' "$current_ip" > "$TMP_FILE"
  mv "$TMP_FILE" "$STATE_FILE"
  chmod 0644 "$STATE_FILE"
  log_line "[SUCCESS] DDNS updated to $current_ip; response: $response"
  exit 0
fi

log_line "[ERROR] DDNS update failed; response: ${response:-<empty>}"
exit 1
