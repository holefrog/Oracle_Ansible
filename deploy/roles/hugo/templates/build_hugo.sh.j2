#!/bin/bash
# ANSIBLE MANAGED: Hugo compilation wrapper

cd "{{ app_user_home }}/hugo" || exit 1

{{ hugo_path }} --gc --cleanDestinationDir \
  -b "https://{{ domain }}{% if sentinel_prefix %}/{{ sentinel_prefix }}{% endif %}/" \
  --destination "{{ web_base }}/{{ domain }}{% if sentinel_prefix %}/{{ sentinel_prefix }}{% endif %}"
